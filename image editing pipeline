        "import modal\n",
        "import os\n",
        "import json\n",
        "import shutil\n",
        "\n",
        "# 1. Environment Setup\n",
        "image = (\n",
        "    modal.Image.debian_slim(python_version=\"3.12\")\n",
        "    .pip_install(\n",
        "        \"torch\", \"torchvision\", \"transformers\", \"diffusers\", \"accelerate\", \n",
        "        \"peft\", \"protobuf\", \"sentencepiece\", \"bitsandbytes\", \n",
        "        \"huggingface_hub\", \"datasets\", \"pillow\", \"qwen-vl-utils\"\n",
        "    )\n",
        ")\n",
        "\n",
        "app = modal.App(\"indibench-split-pipeline\")\n",
        "volume = modal.Volume.from_name(\"flux-results-vol\", create_if_missing=True)\n",
        "\n",
        "# Shared configuration\n",
        "BASE_DIR = \"/results/indibench_pairs\"\n",
        "DIRS = {\n",
        "    \"orig_img\": f\"{BASE_DIR}/original_images\",\n",
        "    \"west_img\": f\"{BASE_DIR}/western_images\",\n",
        "}\n",
        "\n",
        "# =========================================================================\n",
        "# FUNCTION 1: ANALYZE (Qwen Only) - ISOLATED CONTAINER\n",
        "# =========================================================================\n",
        "@app.function(\n",
        "    image=image,\n",
        "    gpu=\"L40S\", # Explicitly requesting L40S (48GB) to be safe\n",
        "    volumes={\"/results\": volume},\n",
        "    secrets=[modal.Secret.from_dict({\"HF_TOKEN\": \"hf_kYjrKbWgyvayFAcZJldjpfcFNqVGGj$$$$\"})]\n",
        ")\n",
        "def step_1_analyze(count=30):\n",
        "    import torch\n",
        "    from datasets import load_dataset\n",
        "    from transformers import Qwen2_5_VLForConditionalGeneration, AutoProcessor, BitsAndBytesConfig\n",
        "    \n",
        "    # Ensure dirs exist\n",
        "    for d in DIRS.values():\n",
        "        os.makedirs(d, exist_ok=True)\n",
        "\n",
        "    print(f\"\ud83e\udde0 [Step 1] Loading Qwen2.5-VL on FRESH GPU...\")\n",
        "    \n",
        "    # Load Qwen (4-bit to be efficient)\n",
        "    bnb_config = BitsAndBytesConfig(load_in_4bit=True, bnb_4bit_compute_dtype=torch.float16)\n",
        "    model = Qwen2_5_VLForConditionalGeneration.from_pretrained(\n",
        "        \"Qwen/Qwen2.5-VL-7B-Instruct\", quantization_config=bnb_config, device_map=\"auto\"\n",
        "    )\n",
        "    processor = AutoProcessor.from_pretrained(\"Qwen/Qwen2.5-VL-7B-Instruct\")\n",
        "\n",
        "    dataset = load_dataset(\"13ari/DRISHTIKON\", split=\"train\", streaming=True)\n",
        "    iterator = iter(dataset)\n",
        "    metadata = []\n",
        "    \n",
        "    print(\"   -> Processing Captions...\")\n",
        "    for i in range(count):\n",
        "        try:\n",
        "            item = next(iterator)\n",
        "            img = item['image'].convert(\"RGB\")\n",
        "            \n",
        "            # --- Extract Indian Caption ---\n",
        "            indian_caption = \"unknown_indian_object\"\n",
        "            if 'label' in item and item['label'] is not None:\n",
        "                indian_caption = str(item['label']) \n",
        "            if 'image_file_path' in item:\n",
        "                path_parts = str(item['image_file_path']).split('/')\n",
        "                if len(path_parts) > 1:\n",
        "                    indian_caption = path_parts[-2] \n",
        "            elif 'filename' in item:\n",
        "                 indian_caption = str(item['filename']).split('.')[0]\n",
        "            \n",
        "            indian_caption = indian_caption.replace(\"_\", \" \").title()\n",
        "\n",
        "            # --- Generate Hard Negative ---\n",
        "            query = \"Identify the specific Indian cultural object. Then, name its closest modern Western equivalent object that looks similar but is culturally different. Return ONLY the Western Name.\"\n",
        "            messages = [{\"role\": \"user\", \"content\": [{\"type\": \"image\", \"image\": img}, {\"type\": \"text\", \"text\": query}]}]\n",
        "            text_input = processor.apply_chat_template(messages, tokenize=False, add_generation_prompt=True)\n",
        "            inputs = processor(text=[text_input], images=[img], padding=True, return_tensors=\"pt\").to(\"cuda\")\n",
        "\n",
        "            with torch.no_grad():\n",
        "                output = model.generate(**inputs, max_new_tokens=15)\n",
        "            \n",
        "            western_caption = processor.batch_decode(output, skip_special_tokens=True)[0].split(\"assistant\")[-1].strip()\n",
        "            \n",
        "            # Save Original Image immediately to Volume\n",
        "            safe_ind = indian_caption.replace(\" \", \"_\").replace(\"/\", \"-\")\n",
        "            safe_west = western_caption.replace(\" \", \"_\").replace(\"/\", \"-\")\n",
        "            filename_base = f\"{i:03d}_{safe_ind}_VS_{safe_west}\"\n",
        "            orig_path = f\"{DIRS['orig_img']}/{filename_base}_ORIG.jpg\"\n",
        "            img.save(orig_path)\n",
        "\n",
        "            metadata.append({\n",
        "                \"id\": i,\n",
        "                \"original_caption\": indian_caption,\n",
        "                \"western_caption\": western_caption,\n",
        "                \"prompt\": f\"A high-quality photo of {western_caption}, modern western style, cinematic lighting, highly detailed, 8k, photorealistic\",\n",
        "                \"filename_base\": filename_base,\n",
        "                \"original_image_path\": orig_path\n",
        "            })\n",
        "            print(f\"     [{i+1}/{count}] {indian_caption} -> {western_caption}\")\n",
        "            \n",
        "        except StopIteration:\n",
        "            break\n",
        "\n",
        "    # Save Metadata for Step 2\n",
        "    json_path = f\"{BASE_DIR}/intermediate_metadata.json\"\n",
        "    with open(json_path, \"w\") as f:\n",
        "        json.dump(metadata, f, indent=4)\n",
        "    \n",
        "    volume.commit()\n",
        "    print(\"\u2705 Step 1 Complete. Container closing (releasing GPU).\")\n",
        "    return len(metadata)\n",
        "\n",
        "# =========================================================================\n",
        "# FUNCTION 2: GENERATE (Flux Only) - ISOLATED CONTAINER\n",
        "# =========================================================================\n",
        "@app.function(\n",
        "    image=image,\n",
        "    gpu=\"L40S\", # Fresh L40S instance (48GB VRAM)\n",
        "    timeout=3600,\n",
        "    volumes={\"/results\": volume},\n",
        "    secrets=[modal.Secret.from_dict({\"HF_TOKEN\": \"hf_kYjrKbWgyvayFAcZJldjpfcFNqVGGjf$$$\"})]\n",
        ")\n",
        "def step_2_generate():\n",
        "    import torch\n",
        "    from diffusers import FluxImg2ImgPipeline\n",
        "    from PIL import Image\n",
        "\n",
        "    print(\"\ud83c\udfa8 [Step 2] Loading FLUX.1-dev on FRESH GPU...\")\n",
        "    \n",
        "    # Load Metadata\n",
        "    json_path = f\"{BASE_DIR}/intermediate_metadata.json\"\n",
        "    if not os.path.exists(json_path):\n",
        "        print(\"\u274c Metadata not found. Run Step 1 first.\")\n",
        "        return []\n",
        "\n",
        "    with open(json_path, \"r\") as f:\n",
        "        metadata = json.load(f)\n",
        "\n",
        "    # L40S has 48GB, so we can run Flux Dev natively (no CPU offload needed, faster!)\n",
        "    pipe = FluxImg2ImgPipeline.from_pretrained(\n",
        "        \"black-forest-labs/FLUX.1-dev\", \n",
        "        torch_dtype=torch.bfloat16\n",
        "    ).to(\"cuda\")\n",
        "\n",
        "    final_records = []\n",
        "    \n",
        "    for meta in metadata:\n",
        "        print(f\"  Generating: {meta['western_caption']}...\")\n",
        "        \n",
        "        # Load original from volume\n",
        "        orig_img = Image.open(meta['original_image_path']).convert(\"RGB\")\n",
        "        \n",
        "        # Generate\n",
        "        generated_image = pipe(\n",
        "            prompt=meta['prompt'],\n",
        "            image=orig_img,\n",
        "            strength=0.80, \n",
        "            guidance_scale=3.5, \n",
        "            num_inference_steps=25 \n",
        "        ).images[0]\n",
        "\n",
        "        west_path = f\"{DIRS['west_img']}/{meta['filename_base']}_WEST.jpg\"\n",
        "        generated_image.save(west_path)\n",
        "        \n",
        "        meta['western_image_path'] = west_path\n",
        "        final_records.append(meta)\n",
        "\n",
        "    # Save Final\n",
        "    final_json_path = f\"{BASE_DIR}/indibench_metadata.json\"\n",
        "    with open(final_json_path, \"w\") as f:\n",
        "        json.dump(final_records, f, indent=4)\n",
        "        \n",
        "    volume.commit()\n",
        "    return final_records\n",
        "\n",
        "# --- Execution ---\n",
        "if __name__ == \"__main__\":\n",
        "    local_folder = \"vlg_research_final\"\n",
        "    if os.path.exists(local_folder):\n",
        "        shutil.rmtree(local_folder)\n",
        "    os.makedirs(local_folder)\n",
        "\n",
        "    with app.run():\n",
        "        print(\"\u25b6\ufe0f STARTING STEP 1: ANALYSIS\")\n",
        "        count = step_1_analyze.remote(count=30)\n",
        "        \n",
        "        print(f\"\u25b6\ufe0f STARTING STEP 2: GENERATION (Processed {count} items)\")\n",
        "        results = step_2_generate.remote()\n",
        "        \n",
        "        print(f\"\ud83d\udce5 Downloading files...\")\n",
        "        vol = modal.Volume.from_name(\"flux-results-vol\")\n",
        "        \n",
        "        # Helper to read volume\n",
        "        def download(remote, local):\n",
        "            try:\n",
        "                with open(local, \"wb\") as f:\n",
        "                    for chunk in vol.read_file(remote):\n",
        "                        f.write(chunk)\n",
        "            except Exception:\n",
        "                pass # Skip if missing\n",
        "\n",
        "        download(\"indibench_pairs/indibench_metadata.json\", f\"{local_folder}/dataset_manifest.json\")\n",
        "\n",
        "        for res in results:\n",
        "            orig = os.path.basename(res['original_image_path'])\n",
        "            west = os.path.basename(res['western_image_path'])\n",
        "            download(f\"indibench_pairs/original_images/{orig}\", f\"{local_folder}/{orig}\")\n",
        "            download(f\"indibench_pairs/western_images/{west}\", f\"{local_folder}/{west}\")\n",
        "\n",
        "        print(f\"\\n\u2705 SUCCESS! Data saved to '{local_folder}'.\")"
